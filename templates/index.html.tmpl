<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>$page_title</title>
    <meta name="description" content="$meta_description" />
    <link rel="stylesheet" href="$assets_prefix/assets/styles/site.css" />
    <script defer src="$assets_prefix/assets/scripts/site.js"></script>
  </head>
  <body class="page-home">
    <main>
      <section class="hero hero-home">
        <div class="hero-copy reveal">
          <p class="eyebrow">$brand_label</p>
          <h1 class="brand-mark">$hero_title</h1>
          <p class="hero-text">$hero_subtitle</p>
        </div>
        <div class="product-rail">$product_cards</div>
      </section>
    </main>

    <footer class="site-footer">
      <p>$footer_note</p>
      <p class="footer-meta">SLITE TOOLS / $year</p>
    </footer>
  </body>
</html>
