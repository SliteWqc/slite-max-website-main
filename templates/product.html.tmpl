<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>$page_title</title>
    <meta name="description" content="$meta_description" />
    <link rel="stylesheet" href="$assets_prefix/assets/styles/site.css" />
    <script defer src="$assets_prefix/assets/scripts/site.js"></script>
  </head>
  <body class="page-product">
    <main>
      <section class="product-hero">
        <div class="product-copy reveal">
          <a class="back-link" href="$home_href">返回首页</a>
          <p class="eyebrow">$brand_label</p>
          <h1>$product_title</h1>
          <p class="product-subtitle">$product_subtitle</p>
          <p class="product-description">$product_description</p>
          <div class="cta-row">
            <a class="button-primary" href="$download_url" target="_blank" rel="noreferrer">下载占位</a>
          </div>
        </div>
        <figure class="product-visual reveal">
          <img src="$product_image" alt="$product_title 界面预览" />
        </figure>
      </section>

      <section class="content-placeholder reveal">
        <div>
          <p class="section-kicker">Content</p>
          <h2>详细内容占位</h2>
          <p>$detail_placeholder</p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>$footer_note</p>
      <p class="footer-meta">SLITE TOOLS / $year</p>
    </footer>
  </body>
</html>
